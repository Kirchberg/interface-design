#!/usr/bin/env python3
"""Synchronize generated install surfaces from tool-neutral sources.

Canonical sources:
  install-surfaces/manifest.json
  skills/interface-design

Generated install surfaces:
  .codex-plugin/plugin.json
  .agents/plugins/marketplace.json
  .claude/skills/interface-design
  .claude/commands/*
  .claude-plugin/plugin.json
  .claude-plugin/marketplace.json
"""

from __future__ import annotations

import argparse
import filecmp
import json
import shutil
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Iterable


ROOT = Path(__file__).resolve().parents[1]
MANIFEST = ROOT / "install-surfaces" / "manifest.json"
CANONICAL_SKILL = ROOT / "skills" / "interface-design"
CLAUDE_SKILL = ROOT / ".claude" / "skills" / "interface-design"
CLAUDE_COMMANDS = ROOT / ".claude" / "commands"
CODEX_PLUGIN = ROOT / ".codex-plugin" / "plugin.json"
AGENTS_MARKETPLACE = ROOT / ".agents" / "plugins" / "marketplace.json"
CLAUDE_PLUGIN = ROOT / ".claude-plugin" / "plugin.json"
CLAUDE_MARKETPLACE = ROOT / ".claude-plugin" / "marketplace.json"


COMMANDS = {
    "init.md": (
        "Use Interface Design",
        "Use the `interface-design` skill for this request. Treat any arguments "
        "as the interface surface, product context, or direction to apply."
    ),
    "status.md": (
        "Show Interface Design status",
        "Use the `interface-design` skill's status behavior: read "
        "`.interface-design/system.md`, summarize direction, tokens, patterns, "
        "and last modified time. If it is missing, suggest extract or first-build setup."
    ),
    "audit.md": (
        "Audit UI against Interface Design memory",
        "Use the `interface-design` skill's audit behavior for the requested path. "
        "Check spacing, depth, color, token, state, and pattern drift against "
        "`.interface-design/system.md`."
    ),
    "extract.md": (
        "Extract Interface Design memory",
        "Use the `interface-design` skill's extract behavior for the requested "
        "frontend paths. Propose `.interface-design/system.md`; write it only after "
        "user confirmation unless explicitly requested."
    ),
    "critique.md": (
        "Critique product UI craft",
        "Use the `interface-design` skill's critique behavior. Review composition, "
        "surface hierarchy, typography, content coherence, states, and structural "
        "hacks; patch weak spots when the user asked for implementation."
    ),
}


@dataclass
class CheckResult:
    ok: bool
    message: str


def load_json(path: Path) -> dict:
    with path.open("r", encoding="utf-8") as handle:
        return json.load(handle)


def dump_json(data: dict) -> str:
    return json.dumps(data, indent=2, ensure_ascii=False) + "\n"


def read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def write_text(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")


def canonical_files() -> list[Path]:
    return sorted(path for path in CANONICAL_SKILL.rglob("*") if path.is_file())


def generated_command(name: str, description: str, body: str) -> str:
    return (
        "---\n"
        f"description: {description}\n"
        "---\n\n"
        "<!-- Generated by scripts/sync-install-surfaces. Do not edit by hand. -->\n\n"
        f"{body}\n\n"
        "Canonical source: `skills/interface-design`.\n\n"
        "Arguments: $ARGUMENTS\n"
    )


def codex_plugin_json(manifest: dict) -> dict:
    data = dict(manifest)
    data["keywords"] = sorted(set(["codex", *manifest.get("keywords", [])]))
    data["skills"] = "./skills/"
    return data


def agents_marketplace_json(manifest: dict) -> dict:
    return {
        "name": manifest["name"],
        "interface": {
            "displayName": manifest.get("interface", {}).get(
                "displayName", manifest["name"]
            )
        },
        "plugins": [
            {
                "name": manifest["name"],
                "source": {
                    "source": "local",
                    "path": "./",
                },
                "policy": {
                    "installation": "AVAILABLE",
                    "authentication": "ON_INSTALL",
                },
                "category": manifest.get("interface", {}).get("category", "Design"),
            }
        ],
    }


def claude_plugin_json(manifest: dict) -> dict:
    return {
        "name": manifest["name"],
        "description": (
            "Claude Code install surface for Interface Design. "
            "Generated from install-surfaces/manifest.json and skills/interface-design."
        ),
        "version": manifest["version"],
        "author": manifest["author"],
        "homepage": manifest["homepage"],
        "repository": manifest["repository"],
        "license": manifest.get("license", "MIT"),
        "commands": "./.claude/commands",
        "skills": "./.claude/skills",
    }


def claude_marketplace_json(manifest: dict) -> dict:
    interface = manifest.get("interface", {})
    return {
        "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
        "name": manifest["name"],
        "metadata": {
            "description": (
                "Claude Code install surface for Interface Design. "
                "Generated from the same manifest and skill source as other surfaces."
            )
        },
        "owner": manifest["author"],
        "plugins": [
            {
                "name": manifest["name"],
                "description": interface.get(
                    "shortDescription", manifest["description"]
                ),
                "version": manifest["version"],
                "author": manifest["author"],
                "source": "./",
                "category": "design",
                "homepage": manifest["homepage"],
                "tags": [
                    "design",
                    "design-system",
                    "ui",
                    "ux",
                    "craft",
                    "memory",
                    "consistency",
                    "tokens",
                    "install-surface",
                ],
            }
        ],
    }


def expected_generated_files() -> dict[Path, bytes]:
    manifest = load_json(MANIFEST)
    expected: dict[Path, bytes] = {}

    for source in canonical_files():
        rel = source.relative_to(CANONICAL_SKILL)
        expected[CLAUDE_SKILL / rel] = source.read_bytes()

    for filename, (description, body) in COMMANDS.items():
        expected[CLAUDE_COMMANDS / filename] = generated_command(
            filename, description, body
        ).encode("utf-8")

    expected[CODEX_PLUGIN] = dump_json(codex_plugin_json(manifest)).encode("utf-8")
    expected[AGENTS_MARKETPLACE] = dump_json(agents_marketplace_json(manifest)).encode("utf-8")
    expected[CLAUDE_PLUGIN] = dump_json(claude_plugin_json(manifest)).encode("utf-8")
    expected[CLAUDE_MARKETPLACE] = dump_json(
        claude_marketplace_json(manifest)
    ).encode("utf-8")
    return expected


def sync_generated_files() -> None:
    if not MANIFEST.exists():
        raise SystemExit(f"Missing install-surface manifest: {MANIFEST}")
    if not CANONICAL_SKILL.exists():
        raise SystemExit(f"Missing canonical skill: {CANONICAL_SKILL}")

    if CLAUDE_SKILL.exists():
        shutil.rmtree(CLAUDE_SKILL)
    if CLAUDE_COMMANDS.exists():
        shutil.rmtree(CLAUDE_COMMANDS)

    for path, content in expected_generated_files().items():
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_bytes(content)


def check_generated_files() -> list[CheckResult]:
    results: list[CheckResult] = []
    expected = expected_generated_files()

    for path, content in expected.items():
        if not path.exists():
            results.append(CheckResult(False, f"Missing generated file: {path}"))
            continue
        if path.read_bytes() != content:
            results.append(CheckResult(False, f"Generated file drifted: {path}"))

    generated_roots = [CLAUDE_SKILL, CLAUDE_COMMANDS]
    expected_paths = set(expected)
    for root in generated_roots:
        if not root.exists():
            continue
        for path in sorted(item for item in root.rglob("*") if item.is_file()):
            if path not in expected_paths:
                results.append(CheckResult(False, f"Unexpected generated file: {path}"))

    if CLAUDE_SKILL.exists() and CANONICAL_SKILL.exists():
        comparison = filecmp.dircmp(CANONICAL_SKILL, CLAUDE_SKILL)
        results.extend(compare_dirs(comparison))

    if not results:
        results.append(CheckResult(True, "Generated install surfaces are synchronized."))
    return results


def compare_dirs(comparison: filecmp.dircmp) -> list[CheckResult]:
    results: list[CheckResult] = []
    for item in comparison.left_only:
        results.append(CheckResult(False, f"Missing in Claude skill mirror: {item}"))
    for item in comparison.right_only:
        results.append(CheckResult(False, f"Extra in Claude skill mirror: {item}"))
    for item in comparison.diff_files:
        results.append(CheckResult(False, f"Different mirrored skill file: {item}"))
    for subdir in comparison.subdirs.values():
        results.extend(compare_dirs(subdir))
    return results


def json_paths() -> list[Path]:
    return [MANIFEST, CODEX_PLUGIN, AGENTS_MARKETPLACE, CLAUDE_PLUGIN, CLAUDE_MARKETPLACE]


def check_json() -> list[CheckResult]:
    results: list[CheckResult] = []
    for path in json_paths():
        try:
            load_json(path)
        except Exception as exc:  # noqa: BLE001 - report exact parse problem.
            results.append(CheckResult(False, f"Invalid JSON {path}: {exc}"))
    if not results:
        results.append(CheckResult(True, "Plugin and marketplace JSON files parse."))
    return results


def skill_paths() -> list[Path]:
    roots = [ROOT / "skills", ROOT / ".claude" / "skills"]
    paths: list[Path] = []
    for root in roots:
        if root.exists():
            paths.extend(sorted(root.glob("*/SKILL.md")))
    return paths


def frontmatter(path: Path) -> dict[str, str]:
    lines = read_text(path).splitlines()
    if not lines or lines[0] != "---":
        raise ValueError("missing opening frontmatter marker")
    try:
        end = lines[1:].index("---") + 1
    except ValueError as exc:
        raise ValueError("missing closing frontmatter marker") from exc

    values: dict[str, str] = {}
    for line in lines[1:end]:
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        values[key.strip()] = value.strip().strip('"').strip("'")
    return values


def check_skill_frontmatter() -> list[CheckResult]:
    results: list[CheckResult] = []
    for path in skill_paths():
        try:
            metadata = frontmatter(path)
        except Exception as exc:  # noqa: BLE001 - report exact metadata problem.
            results.append(CheckResult(False, f"Invalid SKILL.md frontmatter {path}: {exc}"))
            continue
        for key in ("name", "description"):
            if not metadata.get(key):
                results.append(CheckResult(False, f"{path} missing `{key}` frontmatter"))
    if not results:
        results.append(CheckResult(True, "All bundled SKILL.md files have name and description."))
    return results


def check_versions() -> list[CheckResult]:
    try:
        manifest = load_json(MANIFEST)
        codex = load_json(CODEX_PLUGIN)
        claude = load_json(CLAUDE_PLUGIN)
        marketplace = load_json(CLAUDE_MARKETPLACE)
    except Exception as exc:  # noqa: BLE001 - check_json reports the exact file too.
        return [CheckResult(False, f"Cannot compare install surface versions: {exc}")]

    claude_market_version = marketplace["plugins"][0]["version"]
    expected = manifest["version"]
    results = []
    if codex.get("version") != expected:
        results.append(
            CheckResult(False, f"Codex plugin version {codex.get('version')} != {expected}")
        )
    if claude.get("version") != expected:
        results.append(
            CheckResult(False, f"Claude plugin version {claude.get('version')} != {expected}")
        )
    if claude_market_version != expected:
        results.append(
            CheckResult(False, f"Claude marketplace version {claude_market_version} != {expected}")
        )
    if not results:
        results.append(CheckResult(True, "Install surface versions match."))
    return results


def run_checks() -> int:
    checks: list[CheckResult] = []
    checks.extend(check_generated_files())
    checks.extend(check_json())
    checks.extend(check_skill_frontmatter())
    checks.extend(check_versions())

    failed = [result for result in checks if not result.ok]
    for result in checks:
        prefix = "ok" if result.ok else "error"
        print(f"{prefix}: {result.message}")
    return 1 if failed else 0


def parse_args(argv: Iterable[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "--check",
        action="store_true",
        help="Verify generated surfaces without writing files.",
    )
    return parser.parse_args(list(argv))


def main(argv: Iterable[str]) -> int:
    args = parse_args(argv)
    if args.check:
        return run_checks()
    sync_generated_files()
    return run_checks()


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
